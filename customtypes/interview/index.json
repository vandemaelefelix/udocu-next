{
  "id": "interview",
  "label": "Interview",
  "repeatable": true,
  "status": true,
  "format": "custom",
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "name": {
        "type": "Text",
        "config": {
          "label": "Name",
          "placeholder": "Interviewee name"
        }
      },
      "lead": {
        "type": "StructuredText",
        "config": {
          "label": "Lead",
          "single": "paragraph",
          "allowTargetBlank": false
        }
      },
      "body": {
        "type": "StructuredText",
        "config": {
          "label": "Body",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "paragraph,preformatted,heading2,heading3,heading4,strong,em,hyperlink,image,embed,list-item,o-list-item"
        }
      },
      "publish_date": {
        "type": "Date",
        "config": {
          "label": "Publish Date"
        }
      },
      "image_url": {
        "type": "Image",
        "config": {
          "label": "Thumbnail Image",
          "constraint": { "width": 1000, "height": 1000 },
          "thumbnails": []
        }
      },
      "video_url": {
        "type": "Link",
        "config": {
          "label": "Video URL",
          "allowTargetBlank": false,
          "select": "web"
        }
      }
    }
  }
}
